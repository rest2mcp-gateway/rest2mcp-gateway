# Runtime environment: development, test, or production.
NODE_ENV=development

# Host port used by the app for the admin UI, admin API, and runtime endpoints.
PORT=3000

# Network interface to bind to in local or deployed environments.
HOST=0.0.0.0

# Database backend to use.
# Supported values: pglite, postgres.
DATABASE_PROVIDER=pglite

# PostgreSQL connection string.
# Required when DATABASE_PROVIDER=postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rest_to_mcp_admin

# Local data directory used when DATABASE_PROVIDER=pglite.
PGLITE_DATA_DIR=./data/db

# JWT signing secret for authentication tokens.
# In local development, the app can generate an ephemeral value if this is left unset.
JWT_SECRET=change-me

# Key used to encrypt stored secrets.
# In local development, the app can generate and persist this if left unset.
SECRET_ENCRYPTION_KEY=change-me-too

# Authentication mode for the admin application.
# Supported values: local, oidc.
AUTH_MODE=local

# Default organization name bootstrapped on first startup.
BOOTSTRAP_ORG_NAME=Default Organization

# Default organization slug bootstrapped on first startup.
BOOTSTRAP_ORG_SLUG=default

# Bootstrap admin email used for the initial local admin account.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Display name for the initial local admin account.
BOOTSTRAP_ADMIN_NAME=Local Admin

# Password for the initial local admin account when AUTH_MODE=local.
# Optional in local development: if omitted, a password is generated once and
# persisted in ./data/dev-secrets.json next to the PGlite data directory.
BOOTSTRAP_ADMIN_PASSWORD=
