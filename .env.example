# Bootstrap admin username used for the initial local admin account.
BOOTSTRAP_ADMIN_USERNAME=admin

# Password for the initial local admin account.
BOOTSTRAP_ADMIN_PASSWORD=

# Key used to encrypt stored secrets.
# Required in every environment. The application also uses this key to encrypt
# the internally persisted JWT signing secret.
SECRET_ENCRYPTION_KEY=

# Host port used by the app for the admin UI, admin API, and runtime endpoints.
PORT=3000

# Network interface to bind to in local or deployed environments.
HOST=0.0.0.0

# Display name for the initial local admin account.
BOOTSTRAP_ADMIN_NAME=Local Admin


