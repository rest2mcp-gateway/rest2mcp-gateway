{
  "name": "rest-to-mcp-admin-api",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "run-p dev:api dev:frontend",
    "dev:api": "tsx watch src/server.ts",
    "dev:frontend": "npm run build:watch --workspace frontend",
    "start": "node dist/server.js",
    "build": "npm run build --workspace frontend && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "run-s test:backend test:frontend",
    "test:backend": "run-s test:backend:unit test:backend:integration",
    "test:backend:unit": "node --test --import tsx tests/config.service.test.ts tests/secret.serializer.test.ts",
    "test:backend:integration": "node --test --import tsx tests/integration/runtime.workflows.test.ts",
    "test:frontend": "npm run test --workspace frontend",
    "lint:frontend": "npm run lint --workspace frontend",
    "verify:commit": "run-s typecheck",
    "verify:push": "run-s build test:backend:unit test:frontend lint:frontend",
    "verify:ci": "run-s build test:backend:unit test:backend:integration test:frontend lint:frontend",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@scalar/fastify-api-reference": "^1.28.19",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^6.2.2",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.1",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
