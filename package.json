{
  "name": "rest-to-mcp-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "run-p dev:backend dev:frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run build:watch --workspace frontend",
    "start": "npm run start --workspace backend",
    "build": "run-s build:frontend build:backend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "typecheck": "npm run typecheck --workspace backend",
    "export:openapi": "npm run export:openapi --workspace backend",
    "generate:api": "npm run export:openapi && npx openapi-typescript frontend/openapi/admin-api.json -o frontend/src/generated/admin-api.d.ts",
    "check:api": "node scripts/check-generated-api.mjs",
    "test": "run-s test:backend test:frontend",
    "test:backend": "run-s test:backend:unit test:backend:integration",
    "test:backend:unit": "npm run test:unit --workspace backend",
    "test:backend:integration": "npm run test:integration --workspace backend",
    "test:frontend": "npm run test --workspace frontend",
    "lint:frontend": "npm run lint --workspace frontend",
    "verify:commit": "run-s typecheck test:backend:unit",
    "verify:push": "run-s check:api build test:backend:unit test:frontend lint:frontend",
    "verify:ci": "run-s check:api build test:backend:unit test:backend:integration test:frontend lint:frontend",
    "db:generate": "npm run db:generate --workspace backend",
    "db:push": "npm run db:push --workspace backend"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.2",
    "vite": "^8.0.8"
  }
}
