{
  "openapi": "3.1.0",
  "info": {
    "title": "Open-Meteo Forecast Example",
    "version": "1.0.0",
    "description": "Example OpenAPI document for importing an Open-Meteo forecast endpoint into Rest2MC Gateway."
  },
  "servers": [
    {
      "url": "https://api.open-meteo.com"
    }
  ],
  "paths": {
    "/v1/forecast": {
      "get": {
        "operationId": "getForecast",
        "summary": "Get weather forecast",
        "description": "Returns forecast data for a latitude and longitude.",
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude of the requested location."
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude of the requested location."
          },
          {
            "name": "current",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of current weather variables to include."
          },
          {
            "name": "timezone",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Timezone identifier for the returned timestamps."
          }
        ],
        "responses": {
          "200": {
            "description": "Forecast returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ForecastResponse": {
        "type": "object",
        "required": [
          "latitude",
          "longitude",
          "timezone"
        ],
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "timezone": {
            "type": "string"
          },
          "current": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
